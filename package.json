{
  "name": "dev-onboarding-guide",
  "version": "1.0.0",
  "description": "Codebase Onboarding Bot",
  "main": "dist/index.js",
  "bin": {
    "onboard": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format cjs --clean",
    "start": "node dist/index.js",
    "web:install": "cd web && npm install",
    "web:dev": "cd web && npm run dev"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.1.0",
    "@clack/prompts": "^0.9.0",
    "ai": "^4.0.0",
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "picocolors": "^1.0.0",
    "ts-morph": "^22.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
